{
  "name": "interstat",
  "version": "0.3.1",
  "description": "Token efficiency benchmarking, session analytics, and API-equivalent cost analysis for agent workflows",
  "author": "MK",
  "interface": {
    "displayName": "interstat",
    "shortDescription": "Token efficiency benchmarking, session analytics, and API-equivalent cost analysis for agent workflows"
  },
  "skills": "./skills/",
  "hooks": [
    {
      "event": "SessionStart",
      "command": "${KIMI_PLUGIN_ROOT}/hooks/session-start.sh",
      "timeout": 5
    },
    {
      "event": "PostToolUse",
      "matcher": "Agent",
      "command": "${KIMI_PLUGIN_ROOT}/hooks/post-task.sh",
      "timeout": 10
    },
    {
      "event": "PostToolUse",
      "matcher": "*",
      "command": "${KIMI_PLUGIN_ROOT}/hooks/post-tool-all.sh",
      "timeout": 5
    },
    {
      "event": "PostToolUseFailure",
      "command": "${KIMI_PLUGIN_ROOT}/hooks/post-tool-failure.sh",
      "timeout": 5
    },
    {
      "event": "SessionEnd",
      "command": "${KIMI_PLUGIN_ROOT}/hooks/session-end.sh",
      "timeout": 15
    }
  ]
}
